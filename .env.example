# Plesk FTP 部署設定
FTP_HOST=ftp.your-domain.com
FTP_USER=your-ftp-username
FTP_PASSWORD='your-ftp-password' # 避免特殊符號錯誤 請保留單引號
FTP_PORT=21
FTP_SECURE=false
FTP_REMOTE_DIR=/httpdocs
# 排除上傳的檔案或資料夾 (以逗號分隔)
FTP_IGNORE=.env,.git,node_modules,skills,ftp-deploy,ftp-deploy.skill,package-lock.json,README.md

# MySQL/MariaDB 連線設定
    # 正式機
        DB_MAIN_HOST=localhost
        DB_MAIN_PORT=3306
        DB_MAIN_USER=您的帳號
        DB_MAIN_PASS='您的密碼' # 避免特殊符號錯誤 請保留單引號
        DB_MAIN_NAME=您的資料庫名稱
    # 測試機
        DB_TEST_HOST=localhost
        DB_TEST_PORT=3306
        DB_TEST_USER=您的帳號
        DB_TEST_PASS='您的密碼' # 避免特殊符號錯誤 請保留單引號
        DB_TEST_NAME=您的資料庫名稱
    # 單機
        DB_DEV_HOST=localhost
        DB_DEV_PORT=3306
        DB_DEV_USER=您的帳號
        DB_DEV_PASS='您的密碼' # 避免特殊符號錯誤 請保留單引號
        DB_DEV_NAME=您的資料庫名稱