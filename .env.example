# Plesk FTP 部署設定
FTP_HOST=ftp.your-domain.com
FTP_USER=your-ftp-username
FTP_PASSWORD='your-ftp-password' # 避免特殊符號錯誤 請保留單引號
FTP_PORT=21
FTP_SECURE=false
FTP_REMOTE_DIR=/httpdocs
# 排除上傳的檔案或資料夾 (以逗號分隔)
FTP_IGNORE=.git,node_modules,skills,ftp-deploy,ftp-deploy.skill,package-lock.json,README.md,.env

# MySQL/MariaDB 連線設定
# 正式機
DB_MAIN_HOST=localhost
DB_MAIN_PORT=3306
DB_MAIN_USER=your_username
DB_MAIN_PASS='your_password' # 避免特殊符號錯誤 請保留單引號
DB_MAIN_NAME=your_database_name
# 測試機
DB_TEST_HOST=localhost
DB_TEST_PORT=3306
DB_TEST_USER=your_username
DB_TEST_PASS='your_password' # 避免特殊符號錯誤 請保留單引號
DB_TEST_NAME=your_database_name
# 單機
DB_DEV_HOST=localhost
DB_DEV_PORT=3306
DB_DEV_USER=your_username
DB_DEV_PASS='your_password' # 避免特殊符號錯誤 請保留單引號
DB_DEV_NAME=your_database_name